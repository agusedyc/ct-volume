#!/usr/bin/env bash
set -euo pipefail

VERSION="1.1.0"
BACKUP_DIR_DEFAULT="./backups"

# ─── Compose command (auto-detected) ──────────────────────────
_COMPOSE_CMD=""

# ─── Color helpers ──────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; NC='\033[0m'
ok()   { echo -e " ${GREEN}✓${NC} $1" >&2; }
info() { echo -e " ${CYAN}ℹ${NC} $1" >&2; }
warn() { echo -e " ${YELLOW}⚠${NC} $1" >&2; }
err()  { echo -e " ${RED}✗${NC} $1" >&2; }

# ─── Usage ─────────────────────────────────────────────────────
usage() {
  cat <<EOF
Usage: ct-trans <command> [options]

Commands:
  backup       Backup project directory + docker volumes into one archive
  restore      Restore project directory + docker volumes from archive
  vol-backup   Backup named volumes from docker compose
  vol-restore  Restore named volumes from backup archive
  list         List named volumes in the compose file
  inspect      Inspect volume status and size

Global options:
  -f, --file <file>       Compose file path (default: auto-detect)
  -d, --backup-dir <dir>  Backup directory (default: ${BACKUP_DIR_DEFAULT})
  -v, --volume <name>     Target specific volume only (default: all)
  -h, --help              Show this help message
  --version               Show version

Vol-Backup options:
  --retain <N>            Keep only last N backups per volume
  --bundle                Bundle project dir (compose + config + backups) into archive
  -o, --output <dir>      Bundle output directory (default: parent of compose project dir)

Dir-Backup options:
  --restart               Restart services after backup (default: stay stopped)

Vol-Restore options:
  --force                 Skip confirmation prompt
  --bundle <file>         Restore from a bundle archive (extract + restore)

Examples:
  ct-trans backup /path/to/project
  ct-trans restore project-backup-20250709-120000.tar.gz
  ct-trans vol-backup
  ct-trans vol-backup -f docker-compose.prod.yml -d /mnt/backups --retain 7
  ct-trans vol-backup -v postgres_data
  ct-trans vol-backup --bundle -o /tmp
  ct-trans vol-restore
  ct-trans vol-restore -v postgres_data --force
  ct-trans vol-restore --bundle project-web-20250626.tar.gz
  ct-trans list
  ct-trans inspect
  ct-trans inspect -v postgres_data
EOF
  exit 0
}

# ─── Detect compose file ───────────────────────────────────────
detect_compose_file() {
  local file="${1:-}"
  if [[ -n "$file" ]]; then
    echo "$file"
    return 0
  fi
  for candidate in docker-compose.yml compose.yaml docker-compose.yaml compose.yml; do
    if [[ -f "$candidate" ]]; then
      echo "$candidate"
      return 0
    fi
  done
  err "No compose file found. Use -f to specify one."
  exit 1
}

# ─── Extract named volumes from compose config ─────────────────
get_named_volumes() {
  local compose_file="$1"
  local filter_volume="${2:-}"

  local config
  config=$($_COMPOSE_CMD -f "$compose_file" config --format json 2>/dev/null || true)

  local volumes=""
  if [[ -n "$config" ]]; then
    # V2: --format json supported, parse with jq
    if [[ -n "$filter_volume" ]]; then
      volumes=$(echo "$config" | jq -r --arg v "$filter_volume" '
        .volumes // {} | to_entries[] | select(.key == $v) | .key
      ' 2>/dev/null || true)
    else
      volumes=$(echo "$config" | jq -r '
        .volumes // {} | to_entries[] | select(.value.driver == "local" or .value.driver == null) | .key
      ' 2>/dev/null || true)
    fi
  else
    # V1: --format json not supported, use --volumes flag
    volumes=$($_COMPOSE_CMD -f "$compose_file" config --volumes 2>/dev/null || true)

    if [[ -n "$filter_volume" ]]; then
      volumes=$(echo "$volumes" | grep -x "$filter_volume" || true)
    fi
  fi

  if [[ -z "$volumes" ]]; then
    if [[ -n "$filter_volume" ]]; then
      err "Volume '$filter_volume' not found in compose file."
    else
      err "No named volumes found in compose file."
    fi
    exit 1
  fi

  echo "$volumes"
}

# ─── Get volume key→name mapping ─────────────────────────────
# Returns "key|name" pairs (compose key → actual docker volume name)
# For V2: reads .value.name from docker compose config --format json
# For V1: constructs project_key using project name from directory
get_volume_mapping() {
  local compose_file="$1"
  local filter_volume="${2:-}"

  local config
  config=$($_COMPOSE_CMD -f "$compose_file" config --format json 2>/dev/null || true)

  if [[ -n "$config" ]]; then
    if [[ -n "$filter_volume" ]]; then
      echo "$config" | jq -r --arg v "$filter_volume" '
        .volumes // {} | to_entries[] | select(.key == $v) | "\(.key)|\(.value.name)"
      ' 2>/dev/null || true
    else
      echo "$config" | jq -r '
        .volumes // {} | to_entries[] | select(.value.driver == "local" or .value.driver == null) | "\(.key)|\(.value.name)"
      ' 2>/dev/null || true
    fi
  else
    # V1 fallback: construct names using project directory prefix
    local project
    project=$(basename "$(dirname "$(realpath "$compose_file")")")
    project="${project,,}"

    local volumes
    volumes=$($_COMPOSE_CMD -f "$compose_file" config --volumes 2>/dev/null || true)

    if [[ -n "$filter_volume" ]]; then
      volumes=$(echo "$volumes" | grep -x "$filter_volume" || true)
    fi

    echo "$volumes" | while read -r vol; do
      if [[ -n "$vol" ]]; then
        echo "${vol}|${project}_${vol}"
      fi
    done
  fi
}

# ─── Get container status ──────────────────────────────────────
compose_is_running() {
  local compose_file="$1"
  local output
  output=$($_COMPOSE_CMD -f "$compose_file" ps -q 2>/dev/null)
  [[ -n "$output" ]]
}

# ─── Stop services ─────────────────────────────────────────────
compose_down() {
  local compose_file="$1"
  info "Stopping services..."
  $_COMPOSE_CMD -f "$compose_file" down 2>/dev/null || true
  ok "Services stopped."
}

# ─── Start services ────────────────────────────────────────────
compose_up() {
  local compose_file="$1"
  info "Starting services..."
  $_COMPOSE_CMD -f "$compose_file" up -d 2>/dev/null || true
  ok "Services started."
}

# ─── Create bundle archive (project dir + backups) ──────────
create_bundle() {
  local compose_file="$1"
  local bundle_output="$2"
  local timestamp="$3"
  local backup_dir="$4"

  local project_dir
  project_dir=$(dirname "$(realpath "$compose_file")")
  local parent_dir
  parent_dir=$(dirname "$project_dir")
  local dir_name
  dir_name=$(basename "$project_dir")

  local bundle_name="${dir_name}-${timestamp}.tar.gz"
  local bundle_path

  if [[ -n "$bundle_output" ]]; then
    bundle_path="${bundle_output}/${bundle_name}"
    mkdir -p "$bundle_output"
  else
    bundle_path="${parent_dir}/${bundle_name}"
  fi

  echo ""
  info "Creating project bundle: ${bundle_name}"
  tar czf "$bundle_path" -C "$parent_dir" "$dir_name"
  ok "Bundle created: $(realpath "$bundle_path")"
}

# ─── Extract bundle archive ─────────────────────────────────
extract_bundle() {
  local bundle="$1"

  if [[ ! -f "$bundle" ]]; then
    err "Bundle file not found: $bundle"
    exit 1
  fi

  local bundle_dir
  bundle_dir=$(dirname "$(realpath "$bundle")")

  info "Extracting bundle: $(basename "$bundle")"
  tar xzf "$bundle" -C "$bundle_dir"

  local extracted_dir
  extracted_dir=$(tar tzf "$bundle" | head -1 | cut -d/ -f1)

  echo "${bundle_dir}/${extracted_dir}"
}

# ─── List volumes ──────────────────────────────────────────────
cmd_list() {
  local compose_file="$1"
  local filter_volume="${2:-}"

  local volumes
  volumes=$(get_named_volumes "$compose_file" "$filter_volume")

  echo ""
  echo "Named Volumes in: $(basename "$compose_file")"
  echo "────────────────────────────────────────"
  echo "$volumes" | while read -r vol; do
    echo "  $vol"
  done
  echo ""
}

# ─── Backup ────────────────────────────────────────────────────
cmd_backup() {
  local compose_file="$1"
  local backup_dir="$2"
  local filter_volume="$3"
  local retain="${4:-0}"
  local bundle="${5:-false}"
  local bundle_output="$6"

  local volumes
  volumes=$(get_volume_mapping "$compose_file" "$filter_volume")

  mkdir -p "$backup_dir"

  local timestamp
  timestamp=$(date +%Y%m%d-%H%M%S)

  local was_running=false
  if compose_is_running "$compose_file"; then
    was_running=true
    compose_down "$compose_file"
  fi

  local backup_files=()
  local total_size=0

  echo ""
  while IFS='|' read -r key name; do
    [[ -z "$key" ]] && continue
    local archive_name="${timestamp}-${key}.tar.gz"
    local archive_path="${backup_dir}/${archive_name}"

    info "Backing up volume: ${name} → ${archive_name}"

    docker volume inspect "$name" &>/dev/null || docker volume create "$name" &>/dev/null || true

    if docker run --rm \
      -v "${name}:/source:ro" \
      -v "${backup_dir}:/backup" \
      alpine tar czf "/backup/${archive_name}" -C /source .; then
      local size
      size=$(stat --printf="%s" "$archive_path" 2>/dev/null || echo 0)
      total_size=$((total_size + size))
      backup_files+=("$archive_path")
      ok "Backup complete: ${archive_name} ($(numfmt --to=iec-i "$size" 2>/dev/null || echo "${size}B"))"
    else
      warn "Backup failed for volume: ${key}"
    fi
  done <<< "$volumes"

  if [[ "$was_running" == true ]]; then
    compose_up "$compose_file"
  fi

  if [[ ${#backup_files[@]} -eq 0 ]]; then
    err "No backups were created."
    exit 1
  fi

  echo ""
  ok "Backup summary: ${#backup_files[@]} file(s), total $(numfmt --to=iec-i "$total_size" 2>/dev/null || echo "${total_size}B")"
  echo "  Location: $(realpath "$backup_dir")"

  if [[ "$retain" -gt 0 ]]; then
    retain_backups "$backup_dir" "$retain" "$filter_volume"
  fi

  if [[ "$bundle" == "true" ]]; then
    create_bundle "$compose_file" "$bundle_output" "$timestamp" "$backup_dir"
  fi
}

# ─── Retention: prune old backups ──────────────────────────────
retain_backups() {
  local backup_dir="$1"
  local retain="$2"
  local filter_volume="$3"

  echo ""
  info "Running retention policy: keep last ${retain} backup(s) per volume"

  # Group backups by volume name (format: TIMESTAMP-VOLUME.tar.gz)
  find "$backup_dir" -maxdepth 1 -name '*-*.tar.gz' -type f | while read -r path; do
    local basename
    basename=$(basename "$path")
    # Extract volume name after TIMESTAMP- (TIMESTAMP is YYYYMMDD-HHMMSS = 15 chars + hyphen)
    local vol_name="${basename:16}"
    vol_name="${vol_name%.tar.gz}"
    echo "$(date -r "$path" +%s) ${vol_name} ${path}"
  done | sort -k1,1n | while read -r ts vol_name path; do
    echo "$vol_name $path"
  done > /tmp/ct-trans-backups.txt

  # Process each unique volume
  local volumes_seen=""
  while read -r vol_name path; do
    if ! echo "$volumes_seen" | grep -q "^${vol_name}$"; then
      volumes_seen="${volumes_seen}"$'\n'"${vol_name}"
      local count
      count=$(grep -c "^${vol_name} " /tmp/ct-trans-backups.txt 2>/dev/null || echo 0)
      if [[ "$count" -gt "$retain" ]]; then
        local to_delete=$((count - retain))
        grep "^${vol_name} " /tmp/ct-trans-backups.txt | head -n "$to_delete" | while read -r line; do
          local old_path
          old_path=$(echo "$line" | awk '{print $2}')
          rm -f "$old_path"
          ok "Pruned old backup: $(basename "$old_path")"
        done
      fi
    fi
  done < /tmp/ct-trans-backups.txt

  rm -f /tmp/ct-trans-backups.txt
}

# ─── Restore ───────────────────────────────────────────────────
cmd_restore() {
  local compose_file="$1"
  local backup_dir="$2"
  local filter_volume="$3"
  local force="${4:-false}"
  local bundle="$5"

  # If restoring from a bundle, extract it first
  if [[ -n "$bundle" && "$bundle" != "true" ]]; then
    local extracted
    extracted=$(extract_bundle "$bundle")

    # Find compose file in extracted project dir
    local candidate
    for candidate in docker-compose.yml compose.yaml docker-compose.yaml compose.yml; do
      if [[ -f "${extracted}/${candidate}" ]]; then
        compose_file="${extracted}/${candidate}"
        break
      fi
    done

    if [[ ! -f "$compose_file" ]]; then
      err "No compose file found in extracted bundle."
      exit 1
    fi

    backup_dir="${extracted}/backups"
    if [[ ! -d "$backup_dir" ]]; then
      err "No backups directory found in extracted bundle (expected: ${backup_dir})"
      exit 1
    fi

    info "Restoring from bundle: $(basename "$bundle")"
    info "Project: $(basename "$extracted")"
  fi

  if [[ ! -d "$backup_dir" ]]; then
    err "Backup directory not found: $backup_dir"
    exit 1
  fi

  # Build volume name mapping (key → actual docker volume name)
  declare -A vol_map
  while IFS='|' read -r k n; do
    [[ -n "$k" ]] && vol_map["$k"]="$n"
  done < <(get_volume_mapping "$compose_file" "")

  # Determine which archives to restore
  local archives=()
  if [[ -n "$filter_volume" ]]; then
    while IFS= read -r -d '' f; do
      archives+=("$f")
    done < <(find "$backup_dir" -maxdepth 1 -name "*-${filter_volume}.tar.gz" -type f -print0 | sort -z)
    if [[ ${#archives[@]} -eq 0 ]]; then
      err "No backup found for volume '$filter_volume' in $backup_dir"
      exit 1
    fi
    archives=("${archives[-1]}")
  else
    for key in "${!vol_map[@]}"; do
      local latest
      latest=$(find "$backup_dir" -maxdepth 1 -name "*-${key}.tar.gz" -type f -print0 2>/dev/null | sort -z | tr '\0' '\n' | tail -1)
      if [[ -n "$latest" ]]; then
        archives+=("$latest")
      else
        warn "No backup found for volume: ${key}"
      fi
    done

    if [[ ${#archives[@]} -eq 0 ]]; then
      err "No matching backups found in $backup_dir"
      exit 1
    fi
  fi

  # Confirmation unless --force
  if [[ "$force" != "true" ]]; then
    echo ""
    warn "You are about to RESTORE ${#archives[@]} volume(s):"
    for a in "${archives[@]}"; do
      echo "  - $(basename "$a")"
    done
    echo ""
    read -rp "This will OVERWRITE existing volume data. Continue? [y/N] " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
      info "Restore cancelled."
      exit 0
    fi
  fi

  compose_down "$compose_file"

  echo ""
  for archive in "${archives[@]}"; do
    local archive_name
    archive_name=$(basename "$archive")
    # Extract compose key: strip TIMESTAMP- prefix and .tar.gz suffix
    local key="${archive_name:16}"
    key="${key%.tar.gz}"
    # Lookup actual docker volume name
    local vol_name="${vol_map[$key]:-$key}"

    docker volume inspect "$vol_name" &>/dev/null || docker volume create "$vol_name" &>/dev/null

    info "Restoring volume: ${vol_name} ← ${archive_name}"
    if docker run --rm \
      -v "${vol_name}:/dest" \
      -v "${backup_dir}:/backup" \
      alpine tar xzf "/backup/${archive_name}" -C /dest; then
      ok "Restore complete: ${vol_name}"
    else
      warn "Restore failed for volume: ${vol_name}"
    fi
  done

  compose_up "$compose_file"
  ok "Restore finished."
}

# ─── Dir Backup (simple mode) ─────────────────────────────────
cmd_dir_backup() {
  local target_dir="$1"
  local auto_restart="${2:-false}"

  if [[ -z "$target_dir" ]]; then
    err "Usage: ct-trans backup <target-directory>"
    exit 1
  fi

  if [[ ! -d "$target_dir" ]]; then
    err "Target directory not found: $target_dir"
    exit 1
  fi

  target_dir=$(realpath "$target_dir")
  local dir_name
  dir_name=$(basename "$target_dir")

  # Find compose file recursively inside target directory
  local compose_file
  compose_file=$(find "$target_dir" -type f \( -name "docker-compose.yml" -o -name "compose.yaml" -o -name "docker-compose.yaml" -o -name "compose.yml" \) -print -quit 2>/dev/null || true)

  if [[ -z "$compose_file" ]]; then
    err "No docker-compose.yml found in: $target_dir"
    exit 1
  fi

  info "Using compose file: $compose_file"

  # Check container status — ask user to stop or abort
  local was_stopped=false
  if compose_is_running "$compose_file"; then
    warn "Container is still running in: $target_dir"
    echo ""
    read -r -p "Stop services first? [y/N] " reply
    if [[ "$reply" =~ ^[Yy]$ ]]; then
      compose_down "$compose_file"
      was_stopped=true
    else
      err "Aborted by user."
      exit 1
    fi
  fi

  local volumes
  volumes=$(get_volume_mapping "$compose_file" "")

  local timestamp
  timestamp=$(date +%Y%m%d-%H%M%S)

  # Staging area
  local staging
  staging=$(mktemp -d)
  local staging_dir="${staging}/${dir_name}"
  mkdir -p "$staging_dir"

  info "Copying project files..."
  cp -a "$target_dir/." "$staging_dir/"

  # Backup volumes
  local vol_dir="${staging_dir}/volumes"
  mkdir -p "$vol_dir"

  while IFS='|' read -r key name; do
    [[ -z "$key" ]] && continue
    local vol_archive="${key}.tar.gz"
    info "Backing up volume: ${name}"
    docker volume inspect "$name" &>/dev/null || docker volume create "$name" &>/dev/null || true
    if docker run --rm \
      -v "${name}:/source:ro" \
      -v "${vol_dir}:/backup" \
      alpine tar czf "/backup/${vol_archive}" -C /source .; then
      ok "Volume backup: ${vol_archive}"
    else
      warn "Volume backup failed: ${name}"
    fi
  done <<< "$volumes"

  local archive_name="${dir_name}-backup-${timestamp}.tar.gz"
  local archive_path="${PWD}/${archive_name}"

  info "Creating archive: ${archive_name}"
  tar czf "$archive_path" -C "$staging" "$dir_name"
  rm -rf "$staging"

  if [[ "$auto_restart" == "true" && "$was_stopped" == "true" ]]; then
    compose_up "$compose_file"
  fi

  local size
  size=$(stat --printf="%s" "$archive_path" 2>/dev/null || echo 0)
  ok "Backup created: $(realpath "$archive_path") ($(numfmt --to=iec-i "$size" 2>/dev/null || echo "${size}B"))"
}

# ─── Dir Restore (simple mode) ────────────────────────────────
cmd_dir_restore() {
  local backup_file="$1"

  if [[ -z "$backup_file" ]]; then
    err "Usage: ct-trans restore <backup-archive.tar.gz>"
    exit 1
  fi

  if [[ ! -f "$backup_file" ]]; then
    err "Backup file not found: $backup_file"
    exit 1
  fi

  backup_file=$(realpath "$backup_file")
  local archive_name
  archive_name=$(basename "$backup_file")

  info "Extracting archive: ${archive_name}"

  # Extract to current directory
  tar xzf "$backup_file" -C "$PWD"

  # Get top-level directory from archive
  local top_dir
  top_dir=$(tar tzf "$backup_file" | head -1 | cut -d/ -f1 || true)

  local project_dir="${PWD}/${top_dir}"
  local vol_dir=""

  # Detect volume backup location
  if [[ -d "${project_dir}/volumes" ]]; then
    vol_dir="${project_dir}/volumes"
    info "Found volumes in: ${top_dir}/volumes/"
  elif [[ -d "${project_dir}/backups" ]]; then
    vol_dir="${project_dir}/backups"
    info "Found volumes in: ${top_dir}/backups/"
  else
    local count
    count=$(find "$project_dir" -maxdepth 1 -name '*.tar.gz' -type f 2>/dev/null | wc -l)
    if [[ "$count" -gt 0 ]]; then
      vol_dir="$project_dir"
      info "Found ${count} volume archive(s) in: ${top_dir}/"
    fi
  fi

  if [[ -z "$vol_dir" ]]; then
    err "No volume backups found in archive (looked in: ${top_dir}/{volumes,backups,*.tar.gz})"
    exit 1
  fi

  # Resolve expected Docker volume names from compose file in extracted project
  local -A vol_map
  local compose_file
  compose_file=$(find "$project_dir" -type f \( -name "docker-compose.yml" -o -name "compose.yaml" -o -name "docker-compose.yaml" -o -name "compose.yml" \) -print -quit 2>/dev/null || true)
  if [[ -n "$compose_file" ]]; then
    while IFS='|' read -r k n; do
      [[ -n "$k" ]] && vol_map["$k"]="$n"
    done < <(get_volume_mapping "$compose_file" "")
  fi
  # Build reverse map (docker_name → compose_key) for old-format archives
  local -A rev_map
  for k in "${!vol_map[@]}"; do
    rev_map["${vol_map[$k]}"]="$k"
  done

  local restored=0
  while IFS= read -r -d '' f; do
    local fname
    fname=$(basename "$f" .tar.gz)

    # Determine compose key from archive filename
    local compose_key=""
    if [[ "$fname" =~ ^[0-9]{8}-[0-9]{6}-(.+)$ ]]; then
      compose_key="${BASH_REMATCH[1]}"                          # TIMESTAMP-KEY format
    elif [[ -n "${vol_map[$fname]:-}" ]]; then
      compose_key="$fname"                                      # KEY format, found in mapping
    elif [[ -n "${rev_map[$fname]:-}" ]]; then
      compose_key="${rev_map[$fname]}"                          # DOCKER_VOLUME_NAME format
    fi

    # Resolve expected Docker volume name from mapping
    local vol_name=""
    if [[ -n "$compose_key" && -n "${vol_map[$compose_key]:-}" ]]; then
      vol_name="${vol_map[$compose_key]}"
    else
      vol_name="$fname"
      warn "Could not resolve volume mapping for '${fname}', using as-is"
    fi

    info "Restoring volume: ${vol_name} ← $(basename "$f")"
    docker volume inspect "$vol_name" &>/dev/null || docker volume create "$vol_name" &>/dev/null || true
    if docker run --rm \
      -v "${vol_name}:/dest" \
      -v "${vol_dir}:/backup" \
      alpine tar xzf "/backup/$(basename "$f")" -C /dest; then
      ok "Volume restored: ${vol_name}"
      restored=$((restored + 1))
    else
      warn "Restore failed for volume: ${vol_name}"
    fi
  done < <(find "$vol_dir" -maxdepth 1 -name '*.tar.gz' -type f -print0)

  ok "Restore finished. ${restored} volume(s) restored to ${project_dir}"
  info "Run '${_COMPOSE_CMD} up -d' manually inside ${project_dir} when ready."
}

# ─── Inspect volumes ────────────────────────────────────────────
cmd_inspect() {
  local compose_file="$1"
  local filter_volume="${2:-}"

  local volumes
  volumes=$(get_volume_mapping "$compose_file" "$filter_volume")

  echo ""
  printf "%-25s %-40s %-10s %s\n" "Volume" "Docker Name" "Status" "Size"
  echo "──────────────────────────────────────────────────────────────────────────────────"

  while IFS='|' read -r key name; do
    [[ -z "$key" ]] && continue

    local status="missing"
    local size="-"

    if docker volume inspect "$name" &>/dev/null; then
      status="exists"
      size=$(docker run --rm -v "${name}:/vol" alpine du -sh /vol 2>/dev/null | cut -f1 || echo "-")
    fi

    printf "%-25s %-40s %-10s %s\n" "$key" "$name" "$status" "$size"
  done <<< "$volumes"
  echo ""
}

# ─── Ensure jq is available (auto-install if missing) ──────────
ensure_jq() {
  if command -v jq &>/dev/null; then
    return 0
  fi

  warn "jq is required but not installed."

  local pkg_manager=""
  if command -v apt &>/dev/null; then
    pkg_manager="apt"
  elif command -v pacman &>/dev/null; then
    pkg_manager="pacman"
  elif command -v dnf &>/dev/null; then
    pkg_manager="dnf"
  elif command -v yum &>/dev/null; then
    pkg_manager="yum"
  elif command -v brew &>/dev/null; then
    pkg_manager="brew"
  elif command -v apk &>/dev/null; then
    pkg_manager="apk"
  fi

  if [[ -z "$pkg_manager" ]]; then
    err "No supported package manager found. Please install jq manually."
    exit 1
  fi

  local install_cmd=""
  case "$pkg_manager" in
    apt)    install_cmd="sudo apt install -y jq" ;;
    pacman) install_cmd="sudo pacman -S --noconfirm jq" ;;
    dnf)    install_cmd="sudo dnf install -y jq" ;;
    yum)    install_cmd="sudo yum install -y jq" ;;
    brew)   install_cmd="brew install jq" ;;
    apk)    install_cmd="sudo apk add jq" ;;
  esac

  echo ""
  warn "Detected package manager: ${pkg_manager}"
  info "Install command: ${install_cmd}"
  read -rp "Install jq now? [y/N] " confirm
  if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
    err "jq is required. Please install it manually."
    exit 1
  fi

  if eval "$install_cmd"; then
    ok "jq installed successfully."
  else
    err "Failed to install jq. Please install it manually."
    exit 1
  fi
}

# ─── Main ──────────────────────────────────────────────────────
main() {
  if [[ $# -eq 0 ]]; then
    usage
  fi

  local command=""
  local compose_file=""
  local backup_dir="$BACKUP_DIR_DEFAULT"
  local filter_volume=""
  local retain=0
  local force=false
  local auto_restart=false
  local bundle=""
  local bundle_output=""
  local dir_target=""

  # ─── Detect compose command (V2: docker compose, V1: docker-compose)
  if docker compose version &>/dev/null; then
    _COMPOSE_CMD="docker compose"
  elif docker-compose version &>/dev/null; then
    _COMPOSE_CMD="docker-compose"
  fi

  # Parse global args before command
  while [[ $# -gt 0 ]]; do
    case "$1" in
      backup|restore|list|inspect|vol-backup|vol-restore)
        command="$1"
        shift
        break
        ;;
      -h|--help)
        usage
        ;;
      --version)
        echo "ct-trans v${VERSION}"
        exit 0
        ;;
      *)
        err "Unknown option/command: $1"
        usage
        ;;
    esac
  done

  # Parse command-specific args
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--file)
        compose_file="$2"
        shift 2
        ;;
      --file=*)
        compose_file="${1#*=}"
        shift
        ;;
      -d|--backup-dir)
        backup_dir="$2"
        shift 2
        ;;
      --backup-dir=*)
        backup_dir="${1#*=}"
        shift
        ;;
      -v|--volume)
        filter_volume="$2"
        shift 2
        ;;
      --volume=*)
        filter_volume="${1#*=}"
        shift
        ;;
      --retain)
        retain="$2"
        shift 2
        ;;
      --retain=*)
        retain="${1#*=}"
        shift
        ;;
      --force)
        force=true
        shift
        ;;
      --restart)
        if [[ "$command" == "backup" ]]; then
          auto_restart=true
          shift
        else
          err "--restart not supported for '$command'"
          exit 1
        fi
        ;;
      --bundle)
        if [[ "$command" == "vol-backup" ]]; then
          bundle=true
          shift
        elif [[ "$command" == "vol-restore" ]]; then
          bundle="$2"
          shift 2
        else
          err "--bundle not supported for '$command'"
          exit 1
        fi
        ;;
      --bundle=*)
        bundle="${1#*=}"
        shift
        ;;
      -o|--output)
        bundle_output="$2"
        shift 2
        ;;
      --output=*)
        bundle_output="${1#*=}"
        shift
        ;;
      -h|--help)
        usage
        ;;
      *)
        if [[ "$command" == "backup" || "$command" == "restore" ]]; then
          dir_target="$1"
          shift
        else
          err "Unknown option: $1"
          usage
        fi
        ;;
    esac
  done

  if [[ -z "$command" ]]; then
    err "No command specified."
    usage
  fi

  # Validate dependencies
  if ! command -v docker &>/dev/null; then
    err "Required dependency 'docker' not found."
    exit 1
  fi

  if [[ -z $_COMPOSE_CMD ]]; then
    err "Docker Compose not found (tried 'docker compose' and 'docker-compose')."
    exit 1
  fi

  ensure_jq

  # Detect compose file (skip for backup/restore — compose is resolved internally)
  if [[ "$command" == "backup" || "$command" == "restore" ]]; then
    :
  elif [[ "$command" == "vol-restore" && -n "$bundle" && -z "$compose_file" ]]; then
    info "Compose file will be resolved from bundle."
  else
    compose_file=$(detect_compose_file "$compose_file")
    info "Using compose file: $(realpath "$compose_file")"
  fi

  if [[ "$command" == "vol-backup" || "$command" == "vol-restore" ]]; then
    backup_dir=$(mkdir -p "$backup_dir" && cd "$backup_dir" && pwd)
    info "Backup directory: ${backup_dir}"
  fi

  case "$command" in
    backup)
      cmd_dir_backup "$dir_target" "$auto_restart"
      ;;
    restore)
      cmd_dir_restore "$dir_target"
      ;;
    vol-backup)
      cmd_backup "$compose_file" "$backup_dir" "$filter_volume" "$retain" "$bundle" "$bundle_output"
      ;;
    vol-restore)
      cmd_restore "$compose_file" "$backup_dir" "$filter_volume" "$force" "$bundle"
      ;;
    list)
      cmd_list "$compose_file" "$filter_volume"
      ;;
    inspect)
      cmd_inspect "$compose_file" "$filter_volume"
      ;;
  esac
}

main "$@"
