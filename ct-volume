#!/usr/bin/env bash
set -euo pipefail

VERSION="1.0.0"
BACKUP_DIR_DEFAULT="./backups"

# ─── Color helpers ──────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; NC='\033[0m'
ok()   { echo -e " ${GREEN}✓${NC} $1"; }
info() { echo -e " ${CYAN}ℹ${NC} $1"; }
warn() { echo -e " ${YELLOW}⚠${NC} $1"; }
err()  { echo -e " ${RED}✗${NC} $1" >&2; }

# ─── Usage ─────────────────────────────────────────────────────
usage() {
  cat <<EOF
Usage: ct-volume <command> [options]

Commands:
  backup   Backup named volumes from docker compose
  restore  Restore named volumes from backup archive
  list     List named volumes in the compose file

Global options:
  -f, --file <file>       Compose file path (default: auto-detect)
  -d, --backup-dir <dir>  Backup directory (default: ${BACKUP_DIR_DEFAULT})
  -v, --volume <name>     Target specific volume only (default: all)
  -h, --help              Show this help message
  --version               Show version

Backup options:
  --retain <N>            Keep only last N backups per volume

Restore options:
  --force                 Skip confirmation prompt

Examples:
  ct-volume backup
  ct-volume backup -f docker-compose.prod.yml -d /mnt/backups --retain 7
  ct-volume backup -v postgres_data
  ct-volume restore
  ct-volume restore -v postgres_data --force
  ct-volume list
EOF
  exit 0
}

# ─── Detect compose file ───────────────────────────────────────
detect_compose_file() {
  local file="${1:-}"
  if [[ -n "$file" ]]; then
    echo "$file"
    return 0
  fi
  for candidate in docker-compose.yml compose.yaml docker-compose.yaml compose.yml; do
    if [[ -f "$candidate" ]]; then
      echo "$candidate"
      return 0
    fi
  done
  err "No compose file found. Use -f to specify one."
  exit 1
}

# ─── Extract named volumes from compose config ─────────────────
get_named_volumes() {
  local compose_file="$1"
  local filter_volume="${2:-}"

  if ! command -v jq &>/dev/null; then
    err "Required dependency 'jq' not found. Install it first."
    exit 1
  fi

  local config
  config=$(docker compose -f "$compose_file" config --format json 2>/dev/null || true)
  if [[ -z "$config" ]]; then
    # Fallback: try to parse with docker compose v1
    config=$(docker-compose -f "$compose_file" config --format json 2>/dev/null || true)
  fi

  if [[ -z "$config" ]]; then
    err "Failed to parse compose file (docker compose config --format json failed)."
    exit 1
  fi

  local volumes
  if [[ -n "$filter_volume" ]]; then
    volumes=$(echo "$config" | jq -r --arg v "$filter_volume" '
      .volumes // {} | to_entries[] | select(.key == $v) | .key
    ' 2>/dev/null || true)
  else
    volumes=$(echo "$config" | jq -r '
      .volumes // {} | to_entries[] | select(.value.driver == "local" or .value.driver == null) | .key
    ' 2>/dev/null || true)
  fi

  if [[ -z "$volumes" ]]; then
    if [[ -n "$filter_volume" ]]; then
      err "Volume '$filter_volume' not found in compose file."
    else
      err "No named volumes found in compose file."
    fi
    exit 1
  fi

  echo "$volumes"
}

# ─── Get container status ──────────────────────────────────────
compose_is_running() {
  local compose_file="$1"
  local output
  output=$(docker compose -f "$compose_file" ps -q 2>/dev/null)
  [[ -n "$output" ]]
}

# ─── Stop services ─────────────────────────────────────────────
compose_down() {
  local compose_file="$1"
  info "Stopping services..."
  docker compose -f "$compose_file" down 2>/dev/null || true
  ok "Services stopped."
}

# ─── Start services ────────────────────────────────────────────
compose_up() {
  local compose_file="$1"
  info "Starting services..."
  docker compose -f "$compose_file" up -d 2>/dev/null || true
  ok "Services started."
}

# ─── List volumes ──────────────────────────────────────────────
cmd_list() {
  local compose_file="$1"
  local filter_volume="${2:-}"

  local volumes
  volumes=$(get_named_volumes "$compose_file" "$filter_volume")

  echo ""
  echo "Named Volumes in: $(basename "$compose_file")"
  echo "────────────────────────────────────────"
  echo "$volumes" | while read -r vol; do
    echo "  $vol"
  done
  echo ""
}

# ─── Backup ────────────────────────────────────────────────────
cmd_backup() {
  local compose_file="$1"
  local backup_dir="$2"
  local filter_volume="$3"
  local retain="${4:-0}"

  local volumes
  volumes=$(get_named_volumes "$compose_file" "$filter_volume")

  mkdir -p "$backup_dir"

  local timestamp
  timestamp=$(date +%Y%m%d-%H%M%S)

  local was_running=false
  if compose_is_running "$compose_file"; then
    was_running=true
    compose_down "$compose_file"
  fi

  local backup_files=()
  local total_size=0

  echo ""
  while read -r vol; do
    local archive_name="${timestamp}-${vol}.tar.gz"
    local archive_path="${backup_dir}/${archive_name}"

    info "Backing up volume: ${vol} → ${archive_name}"

    if docker run --rm \
      -v "${vol}:/source:ro" \
      -v "${backup_dir}:/backup" \
      alpine tar czf "/backup/${archive_name}" -C /source . 2>/dev/null; then
      local size
      size=$(stat --printf="%s" "$archive_path" 2>/dev/null || echo 0)
      total_size=$((total_size + size))
      backup_files+=("$archive_path")
      ok "Backup complete: ${archive_name} ($(numfmt --to=iec-i "$size" 2>/dev/null || echo "${size}B"))"
    else
      warn "Backup failed for volume: ${vol}"
    fi
  done <<< "$volumes"

  if [[ "$was_running" == true ]]; then
    compose_up "$compose_file"
  fi

  if [[ ${#backup_files[@]} -eq 0 ]]; then
    err "No backups were created."
    exit 1
  fi

  echo ""
  ok "Backup summary: ${#backup_files[@]} file(s), total $(numfmt --to=iec-i "$total_size" 2>/dev/null || echo "${total_size}B")"
  echo "  Location: $(realpath "$backup_dir")"

  if [[ "$retain" -gt 0 ]]; then
    retain_backups "$backup_dir" "$retain" "$filter_volume"
  fi
}

# ─── Retention: prune old backups ──────────────────────────────
retain_backups() {
  local backup_dir="$1"
  local retain="$2"
  local filter_volume="$3"

  echo ""
  info "Running retention policy: keep last ${retain} backup(s) per volume"

  # Group backups by volume name (format: TIMESTAMP-VOLUME.tar.gz)
  find "$backup_dir" -maxdepth 1 -name '*-*.tar.gz' -type f | while read -r path; do
    local basename
    basename=$(basename "$path")
    # Extract volume name after TIMESTAMP- (TIMESTAMP is YYYYMMDD-HHMMSS = 15 chars + hyphen)
    local vol_name="${basename:16}"
    vol_name="${vol_name%.tar.gz}"
    echo "$(date -r "$path" +%s) ${vol_name} ${path}"
  done | sort -k1,1n | while read -r ts vol_name path; do
    echo "$vol_name $path"
  done > /tmp/ct-volume-backups.txt

  # Process each unique volume
  local volumes_seen=""
  while read -r vol_name path; do
    if ! echo "$volumes_seen" | grep -q "^${vol_name}$"; then
      volumes_seen="${volumes_seen}"$'\n'"${vol_name}"
      local count
      count=$(grep -c "^${vol_name} " /tmp/ct-volume-backups.txt 2>/dev/null || echo 0)
      if [[ "$count" -gt "$retain" ]]; then
        local to_delete=$((count - retain))
        grep "^${vol_name} " /tmp/ct-volume-backups.txt | head -n "$to_delete" | while read -r line; do
          local old_path
          old_path=$(echo "$line" | awk '{print $2}')
          rm -f "$old_path"
          ok "Pruned old backup: $(basename "$old_path")"
        done
      fi
    fi
  done < /tmp/ct-volume-backups.txt

  rm -f /tmp/ct-volume-backups.txt
}

# ─── Restore ───────────────────────────────────────────────────
cmd_restore() {
  local compose_file="$1"
  local backup_dir="$2"
  local filter_volume="$3"
  local force="${4:-false}"

  if [[ ! -d "$backup_dir" ]]; then
    err "Backup directory not found: $backup_dir"
    exit 1
  fi

  # Determine which archives to restore
  local archives=()
  if [[ -n "$filter_volume" ]]; then
    while IFS= read -r -d '' f; do
      archives+=("$f")
    done < <(find "$backup_dir" -maxdepth 1 -name "*-${filter_volume}.tar.gz" -type f -print0 | sort -z)
    if [[ ${#archives[@]} -eq 0 ]]; then
      err "No backup found for volume '$filter_volume' in $backup_dir"
      exit 1
    fi
    # Pick the latest backup for this volume
    archives=("${archives[-1]}")
  else
    # Get list of volumes from compose and match with available backups
    local volumes
    volumes=$(get_named_volumes "$compose_file" "")
    while read -r vol; do
      local latest
      latest=$(find "$backup_dir" -maxdepth 1 -name "*-${vol}.tar.gz" -type f -print0 2>/dev/null | sort -z | tr '\0' '\n' | tail -1)
      if [[ -n "$latest" ]]; then
        archives+=("$latest")
      else
        warn "No backup found for volume: ${vol}"
      fi
    done <<< "$volumes"

    if [[ ${#archives[@]} -eq 0 ]]; then
      err "No matching backups found in $backup_dir"
      exit 1
    fi
  fi

  # Confirmation unless --force
  if [[ "$force" != "true" ]]; then
    echo ""
    warn "You are about to RESTORE ${#archives[@]} volume(s):"
    for a in "${archives[@]}"; do
      echo "  - $(basename "$a")"
    done
    echo ""
    read -rp "This will OVERWRITE existing volume data. Continue? [y/N] " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
      info "Restore cancelled."
      exit 0
    fi
  fi

  compose_down "$compose_file"

  echo ""
  for archive in "${archives[@]}"; do
    local archive_name
    archive_name=$(basename "$archive")
    # Extract volume name: strip TIMESTAMP- prefix and .tar.gz suffix
    local vol_name="${archive_name:16}"
    vol_name="${vol_name%.tar.gz}"

    # Ensure volume exists (docker will create it implicitly with :delegated)
    docker volume inspect "$vol_name" &>/dev/null || docker volume create "$vol_name" &>/dev/null

    info "Restoring volume: ${vol_name} ← ${archive_name}"
    if docker run --rm \
      -v "${vol_name}:/dest" \
      -v "${backup_dir}:/backup" \
      alpine tar xzf "/backup/${archive_name}" -C /dest; then
      ok "Restore complete: ${vol_name}"
    else
      warn "Restore failed for volume: ${vol_name}"
    fi
  done

  compose_up "$compose_file"
  ok "Restore finished."
}

# ─── Main ──────────────────────────────────────────────────────
main() {
  if [[ $# -eq 0 ]]; then
    usage
  fi

  local command=""
  local compose_file=""
  local backup_dir="$BACKUP_DIR_DEFAULT"
  local filter_volume=""
  local retain=0
  local force=false

  # Parse global args before command
  while [[ $# -gt 0 ]]; do
    case "$1" in
      backup|restore|list)
        command="$1"
        shift
        break
        ;;
      -h|--help)
        usage
        ;;
      --version)
        echo "ct-volume v${VERSION}"
        exit 0
        ;;
      *)
        err "Unknown option/command: $1"
        usage
        ;;
    esac
  done

  # Parse command-specific args
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--file)
        compose_file="$2"
        shift 2
        ;;
      --file=*)
        compose_file="${1#*=}"
        shift
        ;;
      -d|--backup-dir)
        backup_dir="$2"
        shift 2
        ;;
      --backup-dir=*)
        backup_dir="${1#*=}"
        shift
        ;;
      -v|--volume)
        filter_volume="$2"
        shift 2
        ;;
      --volume=*)
        filter_volume="${1#*=}"
        shift
        ;;
      --retain)
        retain="$2"
        shift 2
        ;;
      --retain=*)
        retain="${1#*=}"
        shift
        ;;
      --force)
        force=true
        shift
        ;;
      -h|--help)
        usage
        ;;
      *)
        err "Unknown option: $1"
        usage
        ;;
    esac
  done

  if [[ -z "$command" ]]; then
    err "No command specified."
    usage
  fi

  # Validate dependencies
  for dep in docker jq; do
    if ! command -v "$dep" &>/dev/null; then
      err "Required dependency '$dep' not found."
      exit 1
    fi
  done

  # Detect compose file
  compose_file=$(detect_compose_file "$compose_file")
  info "Using compose file: $(realpath "$compose_file")"
  info "Backup directory: $(realpath "$(mkdir -p "$backup_dir" && cd "$backup_dir" && pwd)")"

  case "$command" in
    backup)
      cmd_backup "$compose_file" "$backup_dir" "$filter_volume" "$retain"
      ;;
    restore)
      if [[ ! -d "$backup_dir" ]]; then
        mkdir -p "$backup_dir"
      fi
      cmd_restore "$compose_file" "$backup_dir" "$filter_volume" "$force"
      ;;
    list)
      cmd_list "$compose_file" "$filter_volume"
      ;;
  esac
}

main "$@"
